# .gitignore — SS Jewellery backend
# ─────────────────────────────────────────────────────────────────────────────

# ── Python virtual environments ───────────────────────────────────────────────
venv/
venv64/
ENV/
env/
.venv/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Python test & coverage artefacts ─────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Secrets and environment files (NEVER commit these) ────────────────────────
.env
.env.production
.env.local
.env.development
.env.development.local
.env.test.local
.env.production.local
# Allow the example template — it contains placeholders only
!.env.example

# ── SSH private keys (safety net) ─────────────────────────────────────────────
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
deploy_key

# ── Runtime log files ─────────────────────────────────────────────────────────
# Application logs must go to stdout/stderr (captured by Docker).
# Log files must never be committed.
*.log
logs/
backend_app.log
flask_server.log

# ── Database dumps and one-off migration scripts ──────────────────────────────
*.sql
*.dump
*.bak
*.sqlite3
migrate_mysql_to_neon.py
railway_backup.sql

# ── Uploaded media (stored on the server volume, not in git) ──────────────────
backend/static/uploads/
uploads/
media/

# ── Node / frontend build artefacts ──────────────────────────────────────────
node_modules/
dist/
dist-ssr/
build/
*.local

# ── Docker override files (local-only, not committed) ─────────────────────────
docker-compose.override.yml

# ── Editor and OS files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Migration artefacts ───────────────────────────────────────────────────────
# Keep migrations/ in git so Alembic history is preserved.
# Only exclude auto-generated __pycache__ inside the migrations directory.
migrations/__pycache__/
migrations/versions/__pycache__/

# ── Misc leftover files ───────────────────────────────────────────────────────
hi_recovered.json
scratch/
.git_backup/
BB/