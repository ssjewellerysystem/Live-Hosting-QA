# .env.example — Copy to .env on the server and fill in real values.
# NEVER commit .env to version control.
# Keep QA and PROD values strictly separate.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=qa                          # "qa" or "production"
APP_DOMAIN=api.qa.example.com       # Domain Caddy will terminate TLS for
PORT=5000                           # Internal Flask/Gunicorn port
DEBUG=false                         # Must be false in QA and PROD
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR | CRITICAL
GUNICORN_WORKERS=2                  # Adjust based on server CPU count (2 × CPUs + 1)
OTP_MODE=production                 # "development" to expose OTP in API response

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY

# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string — use the pooler URL for production
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require

# ── CORS / Allowed hosts ──────────────────────────────────────────────────────
# Comma-separated. No trailing slashes. No localhost in production.
ALLOWED_HOSTS=api.qa.example.com
CORS_ALLOWED_ORIGINS=https://qa.example.com

# ── Flask-Mail (SMTP) ─────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
SMTP_FROM=SSJewellery <your-email@gmail.com>

# ── Cloudinary (image hosting) ────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Number of trusted reverse proxy hops (1 = Caddy only)
PROXY_FIX_NUM_PROXIES=1
