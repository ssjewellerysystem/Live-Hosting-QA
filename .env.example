# .env.example — Copy to .env on the server and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────
# NEVER commit the real .env file to version control.
# This file is a safe template with placeholder values only.
# Keep QA and PROD .env files strictly separate — different secrets, different
# database URLs, different domains, different Cloudinary accounts.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=qa                           # "qa" or "production"
APP_DOMAIN=api.qa.example.com        # Domain Caddy will terminate TLS for
PORT=5000                            # Internal Flask/Gunicorn port (default 5000)
DEBUG=false                          # Must be false in QA and PROD
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR | CRITICAL
OTP_MODE=production                  # "development" to expose OTP in API response (local only)

# ── Gunicorn workers ──────────────────────────────────────────────────────────
# Formula: (2 × vCPU count) + 1  — but be conservative on small VPS machines.
# QA  (1 CPU / 6 GB RAM):   GUNICORN_WORKERS=2
# PROD (2 CPU / 12 GB RAM): GUNICORN_WORKERS=4
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120                 # Worker timeout in seconds

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
# This value MUST be different in QA and PROD.
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY_64_HEX_CHARS

# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL pooler connection string.
# Use the pooler URL (ending in -pooler.REGION.aws.neon.tech) for production.
# QA and PROD must use completely separate Neon accounts or databases.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require

# ── CORS / Allowed hosts ──────────────────────────────────────────────────────
# Comma-separated. No trailing slashes. No localhost in QA or PROD.
ALLOWED_HOSTS=api.qa.example.com
CORS_ALLOWED_ORIGINS=https://qa.example.com

# ── Flask-Mail (SMTP) ─────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password    # Google App Password (not account password)
SMTP_FROM=SSJewellery <your-email@gmail.com>

# ── Cloudinary (image hosting) ────────────────────────────────────────────────
# QA and PROD should use separate Cloudinary accounts or folders.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Proxy / HTTPS ─────────────────────────────────────────────────────────────
# Number of trusted reverse proxy hops (1 = Caddy only; do not increase)
PROXY_FIX_NUM_PROXIES=1
